{
  "name": "@rimori/client",
  "version": "2.5.35",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/rimori-org/rimori-client.git"
  },
  "license": "Apache-2.0",
  "bin": {
    "rimori-release": "./dist/cli/scripts/release/release.js",
    "rimori-init": "./dist/cli/scripts/init/main.js"
  },
  "type": "module",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./modules": {
      "types": "./dist/modules.d.ts",
      "import": "./dist/modules.js",
      "default": "./dist/modules.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc -w  --preserveWatchOutput",
    "lint": "npx eslint . --fix",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@supabase/postgrest-js": "^2.100.1",
    "dotenv": "^16.5.0",
    "i18next": "^25.10.10"
  },
  "devDependencies": {
    "@types/node": "^25.0.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.46.0"
  }
}
